{
  "datasets": [
    {
      "name": "6dceec10",
      "displayName": "business_sales",
      "config": {
        "version": "1.1",
        "source": "nagadatabricks.dlt_schema.business_sales",
        "dimensions": [
          {
            "name": "region",
            "expr": "source.region",
            "displayName": "Region",
            "comment": "Sales region (East/West)"
          },
          {
            "name": "category",
            "expr": "source.category",
            "displayName": "Category",
            "comment": "Product category"
          },
          {
            "name": "total_sales",
            "expr": "source.total_sales",
            "displayName": "Total Sales",
            "comment": "Sales amount per segment"
          }
        ],
        "measures": [
          {
            "displayName": "Total Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "total_revenue",
            "expr": "SUM(total_sales)",
            "comment": "Sum of all sales"
          },
          {
            "displayName": "Avg Sales",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_sales",
            "expr": "AVG(total_sales)",
            "comment": "Average sales per segment"
          },
          {
            "name": "segment_count",
            "expr": "COUNT(*)",
            "displayName": "Segments",
            "comment": "Number of region-category segments"
          }
        ]
      }
    }
  ],
